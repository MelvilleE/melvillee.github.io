{
    "compilerOptions": {
        "target": "es6",
        "module": "commonjs",
        "jsx": "react",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": "src",
        "paths": {
            "@components/*": ["components/*"],
            "@pages/*": ["pages/*"],
            "@services/*": ["services/*"],
            "@stores/*": ["stores/*"],
            "@hooks/*": ["hooks/*"],
            "@types/*": ["types/*"],
            "@utils/*": ["utils/*"]
        }
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "**/*.spec.ts"
    ]
}